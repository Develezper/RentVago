{
  "name": "rentvago",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "scripts": {
    "preinstall": "bun ./scripts/enforce-bun.mjs",
    "dev": "next dev",
    "build": "bun run db:generate && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:push": "bunx prisma db push",
    "db:seed": "bun run prisma/seed.ts",
    "db:reset": "bunx prisma migrate reset --force --skip-seed --skip-generate && bun run db:generate && bun run db:seed",
    "user:promote": "bun run scripts/promote-user-role.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.7.7",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.9.0",
    "next": "16.2.4",
    "nuqs": "^2.8.9",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.13",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
