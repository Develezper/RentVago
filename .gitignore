/src/generated/prisma

# Docker & Databases
.env
.env.docker
docker_data/
postgres_data/
mysql_data/

# Prisma — las migraciones SÍ se commitean; solo se excluye el cliente generado
# /prisma/migrations  ← NO ignorar: las migraciones deben estar en git 