# ─── Supabase / PostgreSQL ───────────────────────────────────────────────────
# URL con pgbouncer (pooler) — usada por el servidor Next.js en runtime
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?schema=public&pgbouncer=true"

# URL directa (sin pgbouncer) — usada por Prisma para migraciones
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?schema=public"

# ─── Auth JWT ─────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Genera uno seguro con: openssl rand -base64 32
JWT_SECRET="reemplaza-con-una-clave-secreta-de-al-menos-32-caracteres"

# ─── Apify Scraper ────────────────────────────────────────────────────────────
# Token de API de Apify. Obtenerlo en: https://console.apify.com/settings/integrations
APIFY_API_TOKEN="apify_api_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
